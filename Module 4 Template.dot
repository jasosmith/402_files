digraph HealthSystem_FullElementTemplate {
  label="Your Health Problem Here";
  rankdir=TD;
  node [shape=box, style="rounded, filled", fillcolor="white", fontname="Arial"];

//- Add your team number, class section, and names below */


 // Team Number
  // Class Section
  // Team Member Names:


/*  =================================================
   STUDENT INSTRUCTIONS FOR ELEMENT LIST (NON-RENDERING COMMENTS)
   ==================================================
   - Do not remove the area headers
   - If you are not using an element in your system map, comment it out and include your reasonging why it is not included.
   - If you are using an element in your system map, leave it uncommented and include your reasoning why it is included as a comment below it.  
   - If you are changing your mind about including an element from Module 3, include your reasoning for the change as a comment below it.
   See the example below:
*/

// ==================================================
  // EXAMPLE OF FORMATTING ELEMENTS - REMOVE THIS EXAMPLE WHEN YOU SUBMIT YOUR SYSTEM MAP
  // ==================================================

 // primary_care_visit_capacity [label="Primary care visit capacity"];
 // Provide a reason here for why you are eliminating primary care visit capacity from your system map.  For example, "We are not including primary care visit capacity because we are focusing on the role of specialty care in our system map."  If this is a change from Module 3, please explain why you are changing your mind about including this element in your system map.  For example, "We are now including primary care visit capacity because we realized that it is an important factor in our system map."


  primary_care_coordination_capacity [
    label="Primary care care coordination capacity"
  ];
}
// Provide a reason here for why you are including primary care care coordination capacity in your system map.  For example, "We are including primary care care coordination capacity because it is an important factor in our system map that affects access to specialty care."  If this is a change from Module 3, please explain why you are changing your mind about including this element in your system map.  For example, "We are now including primary care care coordination capacity because we realized that it is an important factor in our system map that affects access to specialty care."

// =========================================================
// END OF EXAMPLE OF FORMATTING ELEMENTS
