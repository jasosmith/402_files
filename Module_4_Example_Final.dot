// =================================================
// ELEMENT RELATIONSHIPS
// =================================================





public_health_surveillance_capacity -> state_general_fund_health_allocations [label="+ delay"];

// This relationship indicates that higher public health surveillance capacity leads to increased state general fund health allocations, but with a delay due to the time it takes for data collection, analysis, and reporting to influence funding decisions.

//Harrington, M. L., Chen, S., & Okafor, D. R. (2024). State fiscal responses to expanded epidemiological surveillance infrastructure: A longitudinal analysis of discretionary spending patterns, 2010–2023. American Journal of Fake Health Policy, 18(3), 112–129. https://doi.org/10.1097/ajhp.0000000000000XXX


community_health_program_capacity -> public_health_workforce_capacity [label="+"];
// This relationship indicates that increased community-based health program capacity leads to increased public health workforce capacity, 

//Nguyen, T. A., Patel, R. S., & Washington, C. L. (2023). Community health program expansion and workforce development: Evidence from federally qualified health centers, 2015–2022. Journal of Fake Public Health Management, 29(4), 201–215. https://doi.org/10.1097/jphm.0000000000000YYY

community_health_program_capacity -> income_security [label="+ (long delay ||)"];
// This relationship indicates that increased community-based health program capacity leads to increased income security, but with a delay due to the time it takes for programs to be implemented and economic benefits to be realized.

//Torres, J. M., Kim, B. H., & Osei-Bonsu, P. (2022). Long-run income effects of community health investment: A quasi-experimental study across urban and rural settings. American Journal of Fake Health Economics, 11(2), 77–94. https://doi.org/10.1257/ajfhe.0000000000000ZZZ

medicaid_eligibility_rules -> medicaid_enrollment [label="+ delay (more inclusive rules increase enrollment)"];
// This relationship indicates that more inclusive Medicaid eligibility rules lead to increased Medicaid enrollment, but with a delay due to the time it takes for individuals to become aware of the rules, apply for coverage, and complete the enrollment process.

//Feldman, A. R., Gutierrez, C. M., & Park, S. Y. (2023). Medicaid eligibility expansions and enrollment uptake: A national cross-state analysis, 2014–2021. Journal of Fake Health Policy Research, 45(1), 33–51. https://doi.org/10.1016/j.jfhpr.0000000000000AAA

medicaid_enrollment -> uninsured_population [label="- delay (more enrollment decreases uninsured population)"];
// This relationship indicates that increased Medicaid enrollment leads to a decrease in the uninsured population, but with a delay due to the time it takes for individuals to enroll in Medicaid and for the effects of coverage to be realized.

//Brennan, L. K., Okafor, D. R., & Chen, S. (2021). Medicaid enrollment and the reduction of uninsurance: Panel data evidence from ACA expansion states. Journal of Fake Health Coverage Studies, 8(3), 144–160. https://doi.org/10.1093/jfhcs.0000000000000BBB

state_general_fund_health_allocations -> public_health_grant_funding [label="+"];

// This relationship indicates that increased state general fund health allocations lead to increased community-based health program capacity
// Petrov, I. A., & Diallo, M. S. (2021). State health budget allocations and public health grant program sustainability: A structural equation modeling approach. Fake State Health Finance, 10(2), 38–54. https://doi.org/10.1016/fshf.2021.00038

public_health_workforce_capacity -> preventive_service_availability [label="+"];
// This relationship indicates that increased public health workforce capacity leads to increased availability of preventive services
// Bouchard, C. E., & Nwofor, T. A. (2022). Public health workforce size and preventive service delivery rates: Evidence from accredited local health departments. Fake Preventive Workforce Research, 8(4), 73–89. https://doi.org/10.1097/fpwr.0000000000000073


public_health_grant_funding -> community_health_program_capacity [label="+ delay"];
// This relationship indicates that increased public health grant funding leads to increased community-based health program capacity, but with a delay due to the time it takes for funding to be allocated, programs to be developed, and staff to be hired and trained.
// Rashid, O. T., & Lindberg, S. N. (2023). Grant funding cycles and community health program development timelines: A retrospective analysis. Fake Grant and Program Research, 2(1), 7–23. https://doi.org/10.1016/fgpr.2023.00007
  

public_health_surveillance_capacity -> value_based_payment_adoption [label="+ delay"];
// This relationship indicates that higher public health surveillance capacity leads to increased adoption of value-based payment models, but with a delay due to the time it takes for data collection, analysis, and reporting to influence payment model decisions.
// Obinna, C. H., & Garza, M. R. (2022). Population health surveillance data and value-based contracting adoption among payers and providers. Fake Value-Based Care Research, 6(3), 55–71. https://doi.org/10.1097/fvbcr.0000000000000055

uninsured_population -> income_security [label="- delay"];
// This relationship indicates that a decrease in the uninsured population leads to increased income security, but with a delay due to the time it takes for individuals to gain coverage and for the economic benefits to be realized.
// Kessler, A. J., & Olayinka, B. F. (2021). Health insurance coverage and household financial stability: Evidence from Medicaid expansion counties. Fake Insurance and Economic Security, 14(2), 28–44. https://doi.org/10.1016/fies.2021.00028

racialized_residential_segregation -> income_security [label="- delay"];
// This relationship indicates that higher levels of racialized residential segregation lead to decreased income security, but with a delay due to the time it takes for structural inequities to impact economic opportunities and outcomes.
// Nkemdirim, A. O., & Cohen, R. T. (2023). Residential segregation indices and intergenerational income mobility: A structural racism framework. Fake Structural Racism and Health, 3(2), 14–30. https://doi.org/10.1097/fsrh.0000000000000014

preventive_service_availability -> income_security [label="+ delay"];
// This relationship indicates that increased availability of preventive services leads to increased income security, but with a delay due to the time it takes for individuals to access preventive services and for the health benefits to translate into economic stability.
// Osei-Kwame, P. L., & Dumont, A. F. (2022). Preventive care utilization and long-term labor market outcomes: Evidence from community health center expansion. Fake Prevention and Economic Outcomes, 5(4), 82–98. https://doi.org/10.1016/fpeo.2022.00082

preventive_service_availability -> public_health_surveillance_capacity [label="- long delay"];
// This relationship indicates that increased availability of preventive services leads to decreased public health surveillance capacity, but with a delay due to the time it takes for preventive measures to reduce the incidence of health issues that require surveillance. This is a well-documented phenomenon in public health, where effective prevention can reduce the need for extensive surveillance over time thus reducing prevention and surveillance capacity.
// Achebe, N. I., & Walters, C. M. (2023). Prevention success and surveillance atrophy: A historical analysis of public health funding cycles following disease reduction milestones. Fake Prevention Paradox Research, 1(1), 1–17. https://doi.org/10.1097/fppr.0000000000000001

subgraph cluster_B1 {
        label="Balancing Feedback Loop - Public health victim of its own success";
        style="dashed";
        fontname="Arial";
        fonstsize=10;

        public_health_surveillance_capacity;
        preventive_service_availability;
        public_health_grant_funding;
        community_health_program_capacity;
        state_general_fund_health_allocations;
        public_health_workforce_capacity;

}
// This balancing feedback loop illustrates how increased public health surveillance capacity can lead to increased preventive service availability, which in turn can reduce the need for extensive surveillance over time, creating a balancing effect on the system. Public health can reduce the incidence of health problems. Policy makers believe that surveillance is less necessary when there is not a serious health problem.  Without surveillance there is no data to support the need for funding.  Without funding, there is less capacity to provide preventive services.  Without preventive services, there is more disease and more need for surveillance.  This loop illustrates how public health can be undermined by a lack of investment in prevention and surveillance and it's own success.
// Ikenna, R. O., & Bjornstad, T. L. (2023). Balancing loops in public health systems: How success erodes capacity and the policy implications for sustained investment. Fake Systems Thinking in Public Health, 9(3), 110–127. https://doi.org/10.1016/fstph.2023.00110

//Brennan, L. K., Nguyen, T. A., & Franklin, T. D. (2023). The public health success trap: Systems dynamics evidence for balancing feedback in prevention investment cycles. Journal of Fake Systems and Public Health, 7(4), 233–251. https://doi.org/10.1097/jfsph.0000000000000KKK

}
